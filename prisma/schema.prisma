generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SHOPPER
  SELLER
  ADMIN
}

enum OtpPurpose {
  SIGN_IN
  SIGN_UP
}

enum StoreStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  OUT_OF_STOCK
  ARCHIVED
  PENDING_REVIEW
}

enum OrderStatus {
  PLACED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ReturnRequestType {
  RETURN
  REPLACEMENT
}

enum ReturnRequestStatus {
  REQUESTED
  APPROVED
  PICKUP_SCHEDULED
  PICKED_UP
  REFUND_PENDING
  REFUNDED
  REPLACEMENT_SHIPPED
  REJECTED
}

enum SupportThreadStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

model User {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  name        String?
  email       String?  @unique
  phone       String?  @unique
  avatarUrl   String?
  role        UserRole @default(SHOPPER)
  isActive    Boolean  @default(true)

  otps        OtpCode[]
  cartItems    CartItem[]
  favorites    Favorite[]
  addresses    Address[]
  orders       Order[]
  returnRequests ReturnRequest[]
  applications SellerApplication[]
  store        SellerStore?
  createdProducts Product[]
  supportThreads SupportThread[] @relation("SupportUser")
  assignedSupportThreads SupportThread[] @relation("SupportAssignedAdmin")
  sentSupportMessages SupportMessage[] @relation("SupportSender")
}

model OtpCode {
  id         String      @id @default(cuid())
  createdAt  DateTime    @default(now())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  phone      String
  codeHash   String
  purpose    OtpPurpose
  expiresAt  DateTime
  attempts   Int         @default(0)
  consumedAt DateTime?
}

model Category {
  id         String    @id @default(cuid())
  slug       String    @unique
  name       String
  icon       String
  tint       String
  sortOrder  Int       @default(0)
  isActive   Boolean   @default(true)
  products   Product[]
}

model SellerStore {
  id          String             @id @default(cuid())
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  ownerId     String             @unique
  owner       User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  slug        String             @unique
  description String?
  logoUrl     String?
  coverUrl    String?
  phone       String?
  email       String?
  address     String?
  isOpen      Boolean            @default(true)
  status      StoreStatus        @default(PENDING)
  revenue     Int                @default(0)
  rating      Float              @default(0)
  productCount Int               @default(0)
  ordersCount Int                @default(0)
  products    Product[]
}

model SellerApplication {
  id          String      @id @default(cuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeName   String
  category    String
  gstNumber   String?
  bankLast4   String?
  aadhaarFrontUrl String?
  aadhaarBackUrl  String?
  panCardUrl      String?
  gstCertificateUrl String?
  bankProofUrl    String?
  addressProofUrl String?
  status      StoreStatus @default(PENDING)
  note        String?
}

model Product {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  slug         String        @unique
  title        String
  subtitle     String?
  description  String?
  price        Int
  mrp          Int?
  stock        Int           @default(0)
  rating       Float         @default(0)
  reviewsCount Int           @default(0)
  status       ProductStatus @default(ACTIVE)
  imageUrl     String
  brand        String?
  categoryId   String
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  storeId      String?
  store        SellerStore?  @relation(fields: [storeId], references: [id], onDelete: SetNull)
  creatorId    String?
  creator      User?         @relation(fields: [creatorId], references: [id], onDelete: SetNull)

  cartItems    CartItem[]
  favorites    Favorite[]
  orderItems    OrderItem[]
}

model Testimonial {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  clientName     String
  feedback       String
  rating         Int
  photoUrl       String?
  location       String?
  purchaseDate   String?
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
}

model Favorite {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model CartItem {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity      Int      @default(1)
  selectedSize  String?
  selectedColor String?

  @@unique([userId, productId])
}

model Address {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String
  name        String
  phone       String
  line1       String
  line2       String?
  city        String
  state       String
  postalCode  String
  country     String   @default("India")
  isDefault   Boolean  @default(false)
}

model Order {
  id             String      @id @default(cuid())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  number        String      @unique
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        OrderStatus @default(PLACED)
  paymentMethod String
  couponCode    String?
  discountAmount Int         @default(0)
  shippingFee   Int         @default(0)
  subtotal      Int
  total         Int
  deliveredAt   DateTime?
  trackingNote  String?
  addressLabel  String
  addressName   String
  addressPhone  String
  addressLine1  String
  addressLine2  String?
  addressCity   String
  addressState  String
  addressPostalCode String
  items         OrderItem[]
  events        OrderStatusEvent[]
  returnRequests ReturnRequest[]
}

model OrderStatusEvent {
  id          String      @id @default(cuid())
  createdAt   DateTime    @default(now())
  orderId     String
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status      OrderStatus
  note        String?
  actorRole   UserRole
  actorLabel  String?

  @@index([orderId, createdAt])
}

model OrderItem {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  titleSnapshot String
  priceSnapshot Int
  imageSnapshot String
  quantity      Int
  size          String?
  color         String?
}

model ReturnRequest {
  id                 String               @id @default(cuid())
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  orderId            String
  order              Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId             String
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItemId        String?
  orderNumberSnapshot String
  itemTitleSnapshot  String
  itemImageSnapshot  String
  itemSizeSnapshot   String?
  itemColorSnapshot  String?
  type               ReturnRequestType
  status             ReturnRequestStatus  @default(REQUESTED)
  reason             String
  comments           String?
  photoUrls          String?
  resolutionNote     String?
  actorRole          UserRole?
  actorLabel         String?
  reviewedAt         DateTime?

  @@index([userId, createdAt])
  @@index([orderId, createdAt])
  @@index([status, createdAt])
}

model SupportThread {
  id              String              @id @default(cuid())
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  lastMessageAt   DateTime            @default(now())
  subject         String
  status          SupportThreadStatus @default(OPEN)
  userId          String
  user            User                @relation("SupportUser", fields: [userId], references: [id], onDelete: Cascade)
  assignedAdminId String?
  assignedAdmin   User?               @relation("SupportAssignedAdmin", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  messages        SupportMessage[]

  @@index([status, lastMessageAt])
  @@index([userId, lastMessageAt])
}

model SupportMessage {
  id          String      @id @default(cuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  threadId    String
  thread      SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId    String?
  sender      User?       @relation("SupportSender", fields: [senderId], references: [id], onDelete: SetNull)
  senderRole  UserRole
  senderName  String
  message     String
  attachmentUrl String?
  isSystem    Boolean     @default(false)

  @@index([threadId, createdAt])
}
